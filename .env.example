# --- Database (SQLite) -------------------------------------
# Path is relative to prisma/schema.prisma → resolves to prisma/dev.db
DATABASE_URL="file:./dev.db"

# --- Admin -----------------------------------------------------
SESSION_SECRET="changeme-super-secret"
ADMIN_EMAIL="admin@blackgum.studio"
ADMIN_PASSWORD="changeme"

# --- Stripe ----------------------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Google Sheets Mirror --------------------------------------
GOOGLE_SHEETS_ID="your-google-sheets-id"
GOOGLE_SERVICE_ACCOUNT_EMAIL="booking-bot@project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Admin Block Endpoint --------------------------------------
ADMIN_BLOCK_SECRET="random-block-secret-here"

# --- Public ----------------------------------------------------
NEXT_PUBLIC_BASE_URL="https://blackgum.studio"

# --- Video CDN (Infomaniak hosting, no trailing slash) ---------
# Leave empty to serve from /videos/ locally in dev
NEXT_PUBLIC_VIDEO_CDN=""

# --- Contact (SMTP/Gmail) --------------------------------------
GMAIL_USER="your-gmail@gmail.com"
GMAIL_PASSWORD="your-app-password"
CONTACT_TO_EMAIL="info@blackgumgroup.com"
