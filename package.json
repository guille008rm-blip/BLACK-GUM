{
  "name": "black-gum-studio",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --no-lint",
    "build:strict": "next build",
    "start": "next start",
    "postinstall": "node scripts/ensure-db.js",
    "build:infomaniak": "node scripts/ensure-db.js && npx prisma generate && npx prisma db push --skip-generate && next build --no-lint --experimental-build-mode compile",
    "start:infomaniak": "node ./node_modules/next/dist/bin/next start -p $PORT",
    "lint": "next lint",
    "prisma:generate": "node scripts/ensure-db.js && npx prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "seed": "prisma db seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "googleapis": "^171.4.0",
    "next": "^14.2.0",
    "nodemailer": "^7.0.13",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.34.5",
    "stripe": "^20.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/nodemailer": "^7.0.9",
    "@types/react": "^18.2.62",
    "@types/react-dom": "^18.2.19",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.35",
    "prisma": "^5.10.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2"
  }
}
